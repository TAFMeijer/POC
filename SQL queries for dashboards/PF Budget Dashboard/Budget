SELECT 
      [Country]
      ,[ImplementationPeriodName]
      ,[Module Parent Component]
      ,[Module]
      ,[Intervention]
      ,SUM([Total Amount]) AS 'Total Amount'
  FROM [dbo].[C19RM-GC7 Combined Budget Data]
  WHERE 1=1
  AND [Allocation Cycle] = '2023-2025'
  GROUP BY [Country]
      ,[ImplementationPeriodName]
      ,[Module Parent Component]
      ,[Module]
      ,[Intervention]
ORDER BY 1,2